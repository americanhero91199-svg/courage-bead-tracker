{
  "expo": {
    "name": "Bead Tracker",
    "slug": "courage-bead-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "couragebeads",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFAEB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.couragebeads.tracker",
      "buildNumber": "4",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.couragebeads.tracker",
      "versionCode": 19,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFAEB"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-document-picker",
      "expo-image-picker",
      "expo-system-ui",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "a44bdee4-3dc2-4b1d-bde6-9b367ee724fd"
      }
    },
    "owner": "mrutgardloki"
  }
}
