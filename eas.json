{
  "cli": {
    "version": ">= 13.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PROJECT_ROOT": "artifacts/courage-bead-mobile"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PROJECT_ROOT": "artifacts/courage-bead-mobile"
      }
    },
    "production": {
      "node": "22.0.0",
      "ios": {
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PROJECT_ROOT": "artifacts/courage-bead-mobile"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
